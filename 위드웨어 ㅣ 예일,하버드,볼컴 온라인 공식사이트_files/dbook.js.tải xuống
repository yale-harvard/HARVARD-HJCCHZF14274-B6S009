var frmPath = location.pathname;
var frmSearch = location.search;
var frmPathSearch = location.pathname + location.search;


$(document).ready(function(){

    /* 상단으로 */
	$(".top-btn").click(function(e){
		$("html, body").animate({ scrollTop : 0 }, 600);
		e.preventDefault();
	});

	/* 상,하단 고정 */
	var last_scrollTop = 0;
	$(window).scroll(function () {
		var tmp = $(this).scrollTop();

		if ( tmp > 100 ) {
			if (tmp > last_scrollTop) {
				$('.bottom-nav').addClass('active');
			} else {
				$('.bottom-nav').removeClass('active');
			}
			last_scrollTop = tmp;
		}
	});

	/* 인기 검색어 */
	$(".panel-popular ul").each(function(){
		if ( $(this).find('li').length == 0 ) {
			$(this).parents('.panel-popular').hide();
		} 
	});

	/* 하단 회사 정보 토글 */
	$('#footer .cont-box h3').click(function(){
		$(this).next().slideToggle();
		$(this).toggleClass('on');
	});

	/* 목록 - 중분류 슬라이드 */
	$('.list_item_category').each(function() {
		var mySwiper = new Swiper(this, {
		  spaceBetween: 0,
		  slidesPerView: 'auto',
		  loop: false,
		  grabCursor: true,
		  freeMode: true,
		  watchSlidesProgress: true,
		});

		// 중분류 on 위치
		var _this = $(this);			
		_this.find('> ul > li.on').each(function(){
			var scrollW = _this.find('> ul').width();	
			var onLeft = _this.find('> ul > li.on').position().left;

			if ( scrollW < onLeft + _this.find('> ul > li.on').width() ) {
				mySwiper.slideTo(_this.find('> ul > li.on').index());
			}		
		});	
	});	

	/* 목록 - 정렬타입 토글 */
	if ( $('.body-goods').length )	{

		// 상품 정렬
		$('.sort-select em').click(function(){			
			$(this).toggleClass('on');
			$(this).next().slideToggle(200);
		});
		if(frmSearch.indexOf('sort=') > -1){
			setTimeout(function(){
				$('.sort-select em').text($('.sort-select label.on').text());
			}, 1);
		}
	}

	/* 상세 - 구매안내 토글 */
	$('.item_goods_sec #delivery > div > h3').click(function(){
		$(this).toggleClass('selected').next().slideToggle();
	});
	
});